# Ignore the node_modules directory
# This folder contains installed npm packages.
# It is very large and can be recreated using `npm install`.
node_modules/

# Ignore compiled JavaScript output
# TypeScript compiles files into the dist folder.
# These files are automatically generated with `npm run build`.
dist/

# Ignore test coverage reports
# Browser build output
# These files are generated when building the project for the web.
web-dist/

# Ignore environment variable files
# These sometimes contain sensitive information like API keys.
# This project does not use one, but it is good practice to ignore it.
.env

# Ignore macOS system files
# macOS automatically creates these files in folders.
# They are not part of the project.
.DS_Store

# Ignore log files
# These are temporary files created during debugging or runtime.
*.log